# Hermes RAG Knowledge Base — Environment Variables
# Copy this file to .env and replace YOUR_NEON_PASSWORD

# Neon PostgreSQL (production)
DATABASE_TYPE=postgres
DATABASE_URL=postgresql://neondb_owner:YOUR_NEON_PASSWORD@ep-old-star-abhpdbpp.eu-west-2.aws.neon.tech/rag-kb?sslmode=require&channel_binding=require

# JWT Secret (change in production!)
JWT_SECRET=change-this-to-a-random-secret-in-production

# Server
PORT=3000
