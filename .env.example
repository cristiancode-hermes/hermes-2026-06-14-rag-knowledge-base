# RAG Knowledge Base — Environment Configuration
# Copy this file to .env and fill in your values

# Database (SQLite for dev, PostgreSQL/Neon for production)
DATABASE_URL=data/knowledge.db

# JWT Secret (change in production!)
JWT_SECRET=change-me-to-a-random-secret

# Neon PostgreSQL (optional — for production deployment)
# NEON_DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/rag-kb?sslmode=require

# AI Provider Keys (optional — for LLM-powered answer generation)
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server
PORT=3000
